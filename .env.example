# DependencyGuard MCP — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the HTTP server listens on (default: 8000)
PORT=8000

# ─── NVD API ──────────────────────────────────────────────────────────────────

# Optional but strongly recommended.
# Unauthenticated: 5 requests per 30s
# With API key:   50 requests per 30s
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite cache database file (default: ./dependency-guard.db)
# Created automatically on first run.
DB_PATH=./dependency-guard.db
