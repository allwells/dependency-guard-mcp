{
  "name": "dependency-guard-mcp",
  "version": "1.0.0",
  "description": "MCP tool that returns a prioritized risk verdict for any CVE by combining NIST NVD, CISA KEV, and FIRST EPSS data sources",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun dist/index.js",
    "test": "DB_PATH=:memory: bun test",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
